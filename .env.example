# ──────────────────────────────────────────────────────────────────────────
#  Emerald Plumbing Voice Agent — environment configuration
#  Copy this file to ".env" and fill in real values. Never commit .env.
# ──────────────────────────────────────────────────────────────────────────

# --- Web server ---
PORT=8080
# A shared secret you invent. Set the same value as a custom header in the
# Bland webhook node so the server can reject calls that aren't from Bland.
WEBHOOK_SECRET=change-me-to-a-long-random-string

# --- Bland.ai ---
# From https://app.bland.ai/  -> Settings -> API Keys
BLAND_API_KEY=
# Used only by the pathway builder / number config script.
BLAND_INBOUND_NUMBER=          # e.g. +12025550123 (the number RingCentral forwards to)

# --- ServiceTitan ---
# From the ServiceTitan Developer Portal (https://developer.servicetitan.io).
# Create an app, request the CRM scope, then connect it to the tenant.
ST_CLIENT_ID=
ST_CLIENT_SECRET=
ST_APP_KEY=                    # the "ST-App-Key" header value for your app
ST_TENANT_ID=                  # numeric tenant id
ST_BOOKING_PROVIDER_ID=        # numeric id of the booking provider you create in ST

# ServiceTitan environment endpoints (defaults are production; swap for the
# integration/sandbox environment while testing).
ST_AUTH_URL=https://auth.servicetitan.io/connect/token
ST_API_BASE=https://api.servicetitan.io

# --- Email notification (workorders inbox) ---
# SMTP for the mail host behind emerald911.com (Google Workspace, M365, etc.).
# Leave SMTP_HOST blank to disable email; bookings still go to ServiceTitan.
SMTP_HOST=                     # e.g. smtp.gmail.com or smtp.office365.com
SMTP_PORT=587                  # 587 (STARTTLS) or 465 (SSL)
SMTP_USER=                     # the mailbox/login that sends the notice
SMTP_PASS=                     # app password / SMTP password
FROM_EMAIL=no-reply@emerald911.com
NOTIFY_EMAIL=workorders@emerald911.com
